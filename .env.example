# =============================================================================
# OpenClaw GitRepo Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# ----- Agent Data Directory -----
# Where the agent stores cloned repos, logs, scoring data, and reports.
# Must be an absolute path with sufficient disk space for repo clones.
GITREPO_AGENT_DATA_DIR=/path/to/agent/data

# ----- OpenClaw Agent Claude (ARCHITECT evaluator) -----
# Path to the openclaw-agent-claude for PR scoring via ARCHITECT mode.
# Leave empty to disable ARCHITECT delegation.
OPENCLAW_AGENT_CLAUDE_DIR=/path/to/openclaw-agent-claude

# ----- Azure DevOps -----
# Generate a PAT at https://dev.azure.com/<org>/_usersSettings/tokens
ADO_PAT=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADO_ORG=your-org
ADO_PROJECT=your-project

# ----- GitHub -----
# Generate at https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token

# ----- GitLab (optional) -----
# Generate at https://gitlab.com/-/user_settings/personal_access_tokens
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_URL=https://gitlab.com

# ----- Bitbucket (optional) -----
# Generate at https://bitbucket.org/account/settings/app-passwords/
BITBUCKET_USER=your-username
BITBUCKET_APP_PASSWORD=xxxxxxxxxxxxxxxxxxxx

# ----- Working Hours -----
# PR processing only runs during these hours (24h format, local time)
WORKING_HOURS_START=8
WORKING_HOURS_END=18

# ----- PR Processing -----
# Comma-separated PR IDs to always ignore
IGNORED_PR_IDS=
# Freeze reviewer group name (ADO specific, leave empty if not applicable)
FREEZE_REVIEWER_GROUP=

# ----- Inter-Agent Message Queue (IAMQ) -----
# URL for the OpenClaw Inter-Agent Message Queue HTTP API.
# All agents communicate through this central message bus.
IAMQ_HTTP_URL=http://127.0.0.1:18790
# This agent's unique identifier in the MQ registry.
IAMQ_AGENT_ID=gitrepo_agent
# Heartbeat interval in milliseconds (keeps agent registered as "alive").
IAMQ_HEARTBEAT_MS=60000
# Inbox polling interval in milliseconds (how often to check for new messages).
IAMQ_POLL_MS=30000

# ----- Log Retention -----
LOG_RETENTION_DAYS=30
LOG_COMPRESS_AFTER_DAYS=7
